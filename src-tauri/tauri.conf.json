{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "inkstream",
  "version": "0.1.0",
  "identifier": "com.administrator.inkstream",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1430",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "inkstream",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "resources/pandoc/pandoc.exe": "pandoc/pandoc.exe",
      "resources/pandoc/COPYING.rtf": "pandoc/COPYING.rtf",
      "resources/pandoc/COPYRIGHT.txt": "pandoc/COPYRIGHT.txt"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
